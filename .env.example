# ─────────────────────────────────────────────────────────────
# 🔹 Kizeo Forms
# ─────────────────────────────────────────────────────────────
KIZEO_API_KEY=appi_kizeo_123456789abcdef123456789abcdef12345678   # Token de la API de Kizeo (solicitar a soporte de Kizeo)
KIZEO_WEBHOOK_SECRET=cambia_este_secreto                          # Opcional: valida el header x-webhook-secret del webhook de visitas

# ─────────────────────────────────────────────────────────────
# 🔹 Servidor
# ─────────────────────────────────────────────────────────────
PORT=3000
TZ=America/Bogota                                                 # Zona horaria usada por los schedulers cron

# ─────────────────────────────────────────────────────────────
# 🔹 MongoDB
# La URI debe incluir el nombre de la base de datos (ej: .../kizeo).
# NO se usa MONGODB_DB_NAME: la app conecta con MONGODB_URI directo.
# ─────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://usuario:password@cluster.xxxxx.mongodb.net/kizeo

# ─────────────────────────────────────────────────────────────
# 🔹 Azure AD (app registrada para Microsoft Graph)
# Permisos API requeridos: Files.ReadWrite.All, Sites.ReadWrite.All, Mail.Send
# ─────────────────────────────────────────────────────────────
CLIENT_ID_AD=12345678-90ab-cdef-1234-567890abcdef                 # Application (client) ID
CLIENT_SECRET_AD=abcd1234~Xyz9876_example_secret_key              # Client secret (desde Certificados y secretos)
TENANT_ID_AD=abcdef12-3456-7890-abcd-ef1234567890                 # Directory (tenant) ID
GRAPH_SCOPE=https://graph.microsoft.com/.default                  # Opcional (este es el valor por defecto)

# ─────────────────────────────────────────────────────────────
# 🔹 SharePoint (obtener con Microsoft Graph)
# ─────────────────────────────────────────────────────────────
SITE_ID=example.sharepoint.com,abcd1234-5678-90ab-cdef-1234567890ab,9876abcd-5432-10fe-dcba-abcdef654321
DRIVE_ID=b!exampleDriveId1234567890abcdefgHIJKLmnopqrstUVWX
SITE_URL=https://example.sharepoint.com/sites/NombreDelSitio

# ─────────────────────────────────────────────────────────────
# 🔹 Correos por defecto (Microsoft Graph sendMail)
# Acepta varios destinatarios separados por coma.
# ─────────────────────────────────────────────────────────────
MAIL_DEFAULT_FROM=info@example.net
MAIL_DEFAULT_TO=destinatario@example.net
MAIL_DEFAULT_CC=copia1@example.net,copia2@example.net
MAIL_DEFAULT_BCC=copiaoculta@example.net
